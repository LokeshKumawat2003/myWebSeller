# Backend Environment Variables Example
# Copy this to .env and fill in with your actual values

PORT=5000
MONGO_URI=mongodb://localhost:27017/clothing_store
JWT_SECRET=your_jwt_secret_key_here
NODE_ENV=development

# Twilio Configuration (Required for OTP feature)
TWILIO_ACCOUNT_SID=AC2722ff4150168b08c121f77cb755b736
TWILIO_AUTH_TOKEN=de47de18d3167666c7f5b9c3756dcf5e
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# ShipRocket Configuration (for shipping)
SHIPROCKET_TOKEN=your_shiprocket_token

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend Configuration
CLIENT_URL=http://localhost:3000
